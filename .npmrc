# Repo-local development mirrors for mainland China.
# TUNA's Node.js release mirror is available and helps native rebuild flows.
disturl=https://mirrors.tuna.tsinghua.edu.cn/nodejs-release/

# TUNA's npm registry endpoint is currently not serving package metadata,
# so package installs fall back to the widely used mainland mirror below.
registry=https://registry.npmmirror.com/


# Electron downloads its platform binaries separately from npm metadata.
electron_mirror=https://npmmirror.com/mirrors/electron/

# Native modules in this repo are most reliable on Node 20 + VS 2022 toolchain.
msvs_version=2022
