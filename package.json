{
  "name": "echoes",
  "version": "1.3.9-beta-ver1.0",
  "description": "ECHO desktop application",
  "main": "./out/main/index.js",
  "author": "Moekotori",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext js,jsx,cjs,mjs,ts,tsx --fix",
    "guard:app-jsx": "node scripts/guard-app-jsx-edits.mjs",
    "guard:encoding": "node scripts/guard-encoding.mjs",
    "test:unit": "node --test test/unit/*.test.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "postinstall": "cross-env PYTHONUTF8=1 electron-builder install-app-deps",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "rebuild:native": "cross-env PYTHONUTF8=1 electron-builder install-app-deps",
    "build": "npm run guard:encoding && electron-vite build",
    "build:win": "npm run guard:encoding && npm run build:airplay-raop && electron-vite build && node scripts/build-win.mjs",
    "build:win:release": "npm run guard:encoding && npm run build:airplay-raop && electron-vite build && electron-builder --win -c.directories.output=release",
    "build:mac": "npm run guard:encoding && electron-vite build && electron-builder --mac",
    "build:linux": "npm run guard:encoding && electron-vite build && electron-builder --linux",
    "theme:audit": "node scripts/theme-audit.mjs --write",
    "build:airplay-raop": "node scripts/build-airplay-raop-win.mjs",
    "build:audio-host": "node scripts/build-audio-host.mjs"
  },
  "build": {
    "appId": "com.echoes.studio",
    "productName": "ECHO",
    "icon": "electron-app/build/software.ico",
    "publish": [
      {
        "provider": "github",
        "owner": "Moekotori",
        "repo": "Echoes"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "electron-app/build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/essentia.js/**/*",
      "node_modules/fast-xml-parser/**/*",
      "node_modules/kuroshiro/**/*",
      "node_modules/kuroshiro-analyzer-kuromoji/**/*",
      "node_modules/kuromoji/**/*",
      "node_modules/@babel/runtime/**/*",
      "node_modules/async/**/*",
      "node_modules/doublearray/**/*",
      "node_modules/zlibjs/**/*",
      "node_modules/node-wav/**/*",
      "node_modules/strnum/**/*",
      "node_modules/@lox-audioserver/node-libraop/**/*",
      "node_modules/node-gyp-build/**/*",
      "node_modules/ws/**/*"
    ],
    "extraResources": [
      {
        "from": "NCMconverter.exe",
        "to": "NCMconverter.exe"
      },
      {
        "from": "software.png",
        "to": "software.png"
      },
      {
        "from": "electron-app/build/software.ico",
        "to": "software.ico"
      },
      {
        "from": "electron-app/build",
        "to": ".",
        "filter": [
          "echo-audio-host",
          "echo-audio-host.exe"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron-app/build/software.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "installerIcon": "electron-app/build/software.ico",
      "uninstallerIcon": "electron-app/build/software.ico",
      "createDesktopShortcut": "always",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "electron-app/build/installer.nsh"
    },
    "npmRebuild": false,
    "asarUnpack": [
      "**/node_modules/kuromoji/**",
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/naudiodon/**",
      "**/node_modules/@lox-audioserver/node-libraop/**"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@neteasecloudmusicapienhanced/api": "^4.31.0",
    "axios": "^1.13.6",
    "discord-rpc": "^4.0.1",
    "dompurify": "^3.4.0",
    "electron-updater": "^6.8.3",
    "essentia.js": "^0.1.3",
    "fast-xml-parser": "^5.7.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "html2canvas": "^1.4.1",
    "i18next": "^26.0.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsmediatags": "^3.9.5",
    "kuromoji": "^0.1.2",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "lucide-react": "^0.475.0",
    "marked": "^18.0.0",
    "music-metadata": "^11.12.3",
    "naudiodon": "^2.3.6",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.1",
    "react-youtube": "^10.1.0",
    "ws": "^8.20.0",
    "youtube-dl-exec": "^3.1.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.4",
    "prettier": "^3.4.2",
    "vite": "^5.4.14"
  },
  "optionalDependencies": {
    "@lox-audioserver/node-libraop": "^0.3.3"
  }
}
